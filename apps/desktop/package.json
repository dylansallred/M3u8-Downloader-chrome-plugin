{
  "name": "@m3u8/desktop",
  "version": "2.0.30",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/dylansallred/M3u8-Downloader-chrome-plugin.git"
  },
  "main": "electron/main.js",
  "description": "VidSnag Desktop",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env DEBUG_YTDLP_PROGRESS=1 VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "fetch:yt-dlp": "node ./scripts/fetch-yt-dlp.cjs",
    "fetch:ffmpeg": "node ./scripts/fetch-ffmpeg.cjs",
    "build": "vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@m3u8/contracts": "1.0.0",
    "@m3u8/downloader-api": "1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "40.6.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.dylanallred.m3u8downloader",
    "productName": "VidSnag",
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    }
  }
}
