# Server Configuration
PORT=3000
NODE_ENV=development

# FFmpeg Paths (auto-detected if not specified)
# If ffmpeg/ffprobe are in your PATH, these can be left empty
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe

# External API Keys
# TMDB API - Optional: Used for fetching movie/TV metadata
# Get your key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here_optional

# SubDL API - Required for subtitle downloads
# Without this key, subtitle download functionality will be disabled
# Get your key at: https://subdl.com/api
SUBDL_API_KEY=your_subdl_api_key_here_required_for_subtitles

# Download Configuration
# Maximum number of concurrent download jobs (auto-detected from CPU cores if not set)
# Range: 1-16, Default: auto (based on CPU cores)
MAX_CONCURRENT=2

# Maximum retry attempts for failed segment downloads
# Default: 30
MAX_SEGMENT_ATTEMPTS=30

# Logging
# Options: error, warn, info, debug
# Default: info
LOG_LEVEL=info
